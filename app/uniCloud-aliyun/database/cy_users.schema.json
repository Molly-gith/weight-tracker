{
  "bsonType": "object",
  "required": ["create_date"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "用户ID,系统自动生成"
    },
    "username": {
      "bsonType": "string",
      "description": "用户名(网页端账号密码登录使用)"
    },
    "password_hash": {
      "bsonType": "string",
      "description": "密码的哈希值,不存明文"
    },
    "openid": {
      "bsonType": "string",
      "description": "微信小程序用户唯一标识"
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "注册时间"
    }
  }
}
